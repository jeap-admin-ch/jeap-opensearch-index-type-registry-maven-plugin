{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IndexType Descriptor",
  "description": "JSON schema for OpenSearch IndexType descriptors",
  "$ref": "#/definitions/IndexTypeDescriptor",
  "definitions": {
    "IndexTypeDescriptor": {
      "type": "object",
      "properties": {
        "system": { "type": "string" },
        "originType": { "type": "string" },
        "description": { "type": "string" },
        "documentationUrl": { "type": "string", "format": "uri" },
        "roles": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "mappingVersions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "major": { "type": "integer", "minimum": 1 },
              "minor": { "type": "integer", "minimum": 0 },
              "mappingDefinition": { "type": "string" }
            },
            "required": ["major", "minor", "mappingDefinition"],
            "additionalProperties": false
          }
        }
      },
      "required": ["system", "originType", "description", "roles", "mappingVersions"],
      "additionalProperties": false
    }
  }
}
